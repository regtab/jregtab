[[SKIP]+]
[[SKIP]{2}[VAL: SCHEMA='YEAR']{2}[SKIP]{2}]
{[[VAL#IND: SCHEMA='POLLUTANT'][!@BLANK ? VAL#UNIT: SCHEMA='UNIT'][SKIP]{4}]
[[VAL: SCHEMA='LOCATION'][@BLANK ? SKIP]
[@TEXT MATCHES '\s*-?\s*' ? SKIP | VAL: SCHEMA='VALUE'; RECORD=((ROW:C0);(COL:R1);(UP{1}:C0#IND);(UP{1}:C1#UNIT))]{2}
[SKIP]{2}]+}+