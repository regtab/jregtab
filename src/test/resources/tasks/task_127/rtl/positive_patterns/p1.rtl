[VAL: SCHEMA='AREA']
[VAL: SCHEMA='TIME']
[@TEXT MATCHES '\s*-?\s*' ? SKIP | 
(VAL: SCHEMA='MIN' '-' VAL: SCHEMA='MAX' '<br>' 
